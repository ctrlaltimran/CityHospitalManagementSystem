@model IEnumerable<CityHospitalManagementSystem.Models.Admission>

@{
    ViewData["Title"] = "Admissions";
}

<h1>Admissions</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Admission</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Patient</th>
            <th>Doctor</th>
            <th>Ward</th>
            <th>Bed</th>
            <th>Admission Type</th>
            <th>Admission Date</th>
            <th>Discharge Date</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Patient?.FullName</td>
                <td>@item.Doctor?.FullName</td>
                <td>@item.Ward?.WardName</td>
                <td>@item.Bed?.BedNumber</td>
                <td>@item.AdmissionType</td>
                <td>@item.AdmissionDate.ToString("dd-MMM-yyyy")</td>
                <td>
                    @(item.DischargeDate == null ? "Not Discharged" : item.DischargeDate.Value.ToString("dd-MMM-yyyy"))
                </td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.AdmissionId">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.AdmissionId">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.AdmissionId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>