@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">City Hospital Management System</h1>
        <p class="lead">
            A simple web-based system for managing patients, doctors, admissions, treatments and hospital beds.
        </p>
    </div>

    <div class="row text-center mb-4">
        <div class="col-md-2">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.TotalPatients</h4>
                <p>Total Patients</p>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.TotalDoctors</h4>
                <p>Total Doctors</p>
            </div>
        </div>

        <div class="col-md-2">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.TotalAdmissions</h4>
                <p>Admissions</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.AvailableBeds</h4>
                <p>Available Beds</p>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.OccupiedBeds</h4>
                <p>Occupied Beds</p>
            </div>
        </div>
    </div>

    <div class="row text-center mb-4">
        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.DischargedPatients</h4>
                <p>Discharged Patients</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.EmergencyAdmissions</h4>
                <p>Emergency Admissions</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card p-3 shadow-sm">
                <h4>@ViewBag.MonthlyAdmissions</h4>
                <p>Monthly Patient Inflow</p>
            </div>
        </div>
    </div>

    <div class="row text-center">

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-4">
                <h3>Patients</h3>
                <p>Add, view, update and delete patient records.</p>
                <a asp-controller="Patients" asp-action="Index" class="btn btn-primary">Manage Patients</a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-4">
                <h3>Doctors</h3>
                <p>Manage doctor specialization, ward and availability.</p>
                <a asp-controller="Doctors" asp-action="Index" class="btn btn-success">Manage Doctors</a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-4">
                <h3>Admissions</h3>
                <p>Handle admission, bed assignment and discharge.</p>
                <a asp-controller="Admissions" asp-action="Index" class="btn btn-warning">Manage Admissions</a>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card shadow-sm p-4">
                <h3>Treatments</h3>
                <p>Record treatment details, medicines and notes.</p>
                <a asp-controller="Treatments" asp-action="Index" class="btn btn-info">Manage Treatments</a>
            </div>
        </div>

    </div>
</div>